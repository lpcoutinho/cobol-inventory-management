000100 IDENTIFICATION DIVISION.
000200 PROGRAM-ID. ESTOQUE-FIXED.
000300 AUTHOR. LPCOUTINHO.
000400*----------------------------------------------------------------*
000500 ENVIRONMENT DIVISION.
000600 CONFIGURATION SECTION.
000700 SPECIAL-NAMES.
000800     DECIMAL-POINT IS COMMA.
000900
001000 INPUT-OUTPUT SECTION.
001100 FILE-CONTROL.
001200     SELECT ARQ-ESTOQUE ASSIGN TO 'data/ESTOQUE.dat'
001300     ORGANIZATION IS INDEXED
001400     ACCESS MODE IS DYNAMIC
001500     RECORD KEY IS PROD-ID
001600     FILE STATUS IS WS-FS-ESTOQUE.
001700
001800 DATA DIVISION.
001900 FILE SECTION.
002000 FD  ARQ-ESTOQUE.
002100     COPY 'PRODUTO.cpy'.
002200
002300 WORKING-STORAGE SECTION.
002400 01  WS-FS-ESTOQUE     PIC X(02).
002500 01  WS-OPCAO          PIC X(01).
002600 01  WS-CONFIRMA       PIC X(01).
002700 01  WS-FIM            PIC X(01) VALUE 'N'.
002800 01  WS-FIM-REL        PIC X(01) VALUE 'N'.
002900 01  WS-LINHA          PIC 9(02).
003000
003100 01  WS-MASKS.
003200     05 WS-MASK-PRECO  PIC ZZZ.ZZ9,99.
003300     05 WS-MASK-QTD    PIC ZZZ9.
003400
003500 SCREEN SECTION.
003600 01 TELA-LIMPA.
003700    05 BLANK SCREEN.
003800
003900 01 TELA-MENU.
004000    05 LINE 02 COLUMN 20 VALUE "SISTEMA DE GESTAO DE ESTOQUE"
004100       HIGHLIGHT.
004200    05 LINE 03 COLUMN 20 VALUE "----------------------------".
004300    05 LINE 05 COLUMN 25 VALUE "1. CADASTRAR PRODUTO".
004400    05 LINE 06 COLUMN 25 VALUE "2. CONSULTAR PRODUTO".
004500    05 LINE 07 COLUMN 25 VALUE "3. ALTERAR ESTOQUE".
004600    05 LINE 08 COLUMN 25 VALUE "4. EXCLUIR PRODUTO".
004700    05 LINE 09 COLUMN 25 VALUE "5. RELATORIO GERAL".
004800    05 LINE 11 COLUMN 25 VALUE "0. SAIR".
004900    05 LINE 13 COLUMN 25 VALUE "OPCAO: ".
005000    05 COLUMN PLUS 1 PIC X(01) TO WS-OPCAO.
005100
005200 PROCEDURE DIVISION.
005300 0000-PRINCIPAL.
005400     OPEN I-O ARQ-ESTOQUE.
005500     IF WS-FS-ESTOQUE = '35'
005600         OPEN OUTPUT ARQ-ESTOQUE
005700         CLOSE ARQ-ESTOQUE
005800         OPEN I-O ARQ-ESTOQUE
005900     END-IF.
006000
006100     PERFORM UNTIL WS-FIM = 'S'
006200         DISPLAY TELA-LIMPA
006300         DISPLAY TELA-MENU
006400         ACCEPT TELA-MENU
006500
006600         EVALUATE WS-OPCAO
006700             WHEN '1' PERFORM 1000-CADASTRAR
006800             WHEN '2' PERFORM 2000-CONSULTAR
006900             WHEN '3' PERFORM 3000-ALTERAR
007000             WHEN '4' PERFORM 4000-EXCLUIR
007100             WHEN '5' PERFORM 5000-RELATORIO
007200             WHEN '0' MOVE 'S' TO WS-FIM
007300         END-EVALUATE
007400     END-PERFORM.
007500
007600     CLOSE ARQ-ESTOQUE.
007700     STOP RUN.
007800
007900 1000-CADASTRAR.
008000     DISPLAY TELA-LIMPA.
008100     DISPLAY "CADASTRO DE PRODUTO" LINE 02 COLUMN 25.
008200     DISPLAY "ID    : " LINE 04 COLUMN 20.
008300     ACCEPT PROD-ID LINE 04 COLUMN 28.
008400     DISPLAY "NOME  : " LINE 05 COLUMN 20.
008500     ACCEPT PROD-NOME LINE 05 COLUMN 28.
008600     DISPLAY "QTD   : " LINE 06 COLUMN 20.
008700     ACCEPT PROD-QTD LINE 06 COLUMN 28.
008800     DISPLAY "PRECO : " LINE 07 COLUMN 20.
008900     ACCEPT PROD-PRECO LINE 07 COLUMN 28.
009000
009100     WRITE REG-PRODUTO
009200         INVALID KEY
009300             DISPLAY "ERRO: ID JA CADASTRADO!" LINE 09 COLUMN 20
009400         NOT INVALID KEY
009500             DISPLAY "SUCESSO: PRODUTO SALVO!" LINE 09 COLUMN 20
009600     END-WRITE.
009700     DISPLAY "PRESSIONE ENTER PARA VOLTAR..." LINE 11 COLUMN 20.
009800     ACCEPT WS-OPCAO.
009900
010000 2000-CONSULTAR.
010100     DISPLAY TELA-LIMPA.
010200     DISPLAY "CONSULTA DE PRODUTO" LINE 02 COLUMN 25.
010300     DISPLAY "DIGITE O ID: " LINE 04 COLUMN 20.
010400     ACCEPT PROD-ID LINE 04 COLUMN 35.
010500     READ ARQ-ESTOQUE
010600         INVALID KEY
010700             DISPLAY "PRODUTO NAO ENCONTRADO!" LINE 06 COLUMN 20
010800         NOT INVALID KEY
010900             DISPLAY TELA-LIMPA
011000             DISPLAY "CONSULTA DE PRODUTO" LINE 02 COLUMN 25
011100             DISPLAY "DADOS DO PRODUTO" LINE 04 COLUMN 20
011110                HIGHLIGHT
011200             MOVE PROD-PRECO TO WS-MASK-PRECO
011300             MOVE PROD-QTD   TO WS-MASK-QTD
011400             DISPLAY "ID    : " LINE 06 COLUMN 20
011500             DISPLAY PROD-ID       LINE 06 COLUMN 28
011600             DISPLAY "NOME  : " LINE 07 COLUMN 20
011700             DISPLAY PROD-NOME     LINE 07 COLUMN 28
011800             DISPLAY "QTD   : " LINE 08 COLUMN 20
011900             DISPLAY WS-MASK-QTD   LINE 08 COLUMN 28
012000             DISPLAY "PRECO : R$ " LINE 09 COLUMN 20
012100             DISPLAY WS-MASK-PRECO LINE 09 COLUMN 32
012200     END-READ.
012300     DISPLAY "PRESSIONE ENTER PARA VOLTAR..." LINE 11 COLUMN 20.
012400     ACCEPT WS-OPCAO.
012500
012600 3000-ALTERAR.
012700     DISPLAY TELA-LIMPA.
012800     DISPLAY "ALTERACAO DE PRODUTO" LINE 02 COLUMN 25.
012900     DISPLAY "DIGITE O ID: " LINE 04 COLUMN 20.
013000     ACCEPT PROD-ID LINE 04 COLUMN 35.
013100     READ ARQ-ESTOQUE
013200         INVALID KEY
013300             DISPLAY "PRODUTO NAO ENCONTRADO!" LINE 06 COLUMN 20
013400         NOT INVALID KEY
013500             DISPLAY TELA-LIMPA
013600             DISPLAY "ALTERACAO DE PRODUTO" LINE 02 COLUMN 25
013700             MOVE PROD-PRECO TO WS-MASK-PRECO
013800             MOVE PROD-QTD   TO WS-MASK-QTD
013900             DISPLAY "ID ATUAL: " LINE 04 COLUMN 20 HIGHLIGHT
014000             DISPLAY PROD-ID LINE 04 COLUMN 30 HIGHLIGHT
014100             DISPLAY "NOME ATUAL : " LINE 06 COLUMN 20
014200             DISPLAY PROD-NOME     LINE 06 COLUMN 35
014300             DISPLAY "NOVO NOME  : " LINE 10 COLUMN 20
014400             ACCEPT PROD-NOME LINE 10 COLUMN 35
014500             REWRITE REG-PRODUTO
014600                 INVALID KEY
014700                     DISPLAY "ERRO AO ATUALIZAR!" LINE 14 COLUMN 20
014800                 NOT INVALID KEY
014900                     DISPLAY "SUCESSO!" LINE 14 COLUMN 20
015000             END-REWRITE
015100     END-READ.
015200     DISPLAY "PRESSIONE ENTER PARA VOLTAR..." LINE 16 COLUMN 20.
015300     ACCEPT WS-OPCAO.
015400
015500 4000-EXCLUIR.
015600     DISPLAY TELA-LIMPA.
015700     DISPLAY "EXCLUSAO DE PRODUTO" LINE 02 COLUMN 25.
015800     DISPLAY "DIGITE O ID: " LINE 04 COLUMN 20.
015900     ACCEPT PROD-ID LINE 04 COLUMN 35.
016000     READ ARQ-ESTOQUE
016100         INVALID KEY
016200             DISPLAY "PRODUTO NAO ENCONTRADO!" LINE 06 COLUMN 20
016300         NOT INVALID KEY
016400             DISPLAY "CONFIRMA EXCLUSAO? (S/N): " LINE 08 COLUMN 20
016500             ACCEPT WS-CONFIRMA LINE 08 COLUMN 46
016600             IF WS-CONFIRMA = 'S' OR WS-CONFIRMA = 's'
016700                 DELETE ARQ-ESTOQUE RECORD
016800                 DISPLAY "EXCLUIDO!" LINE 10 COLUMN 20
016900             END-IF
017000     END-READ.
017100     DISPLAY "PRESSIONE ENTER PARA VOLTAR..." LINE 12 COLUMN 20.
017200     ACCEPT WS-OPCAO.
017300
017400 5000-RELATORIO.
017500     DISPLAY TELA-LIMPA.
017600     DISPLAY "RELATORIO GERAL" LINE 02 COLUMN 25 HIGHLIGHT.
017700     MOVE 0 TO PROD-ID.
017800     START ARQ-ESTOQUE KEY IS NOT LESS PROD-ID
017900         INVALID KEY
018000             DISPLAY "VAZIO!" LINE 07 COLUMN 10
018100             MOVE 'S' TO WS-FIM-REL
018200         NOT INVALID KEY
018300             MOVE 'N' TO WS-FIM-REL
018400             MOVE 6 TO WS-LINHA
018500     END-START.
018600     PERFORM UNTIL WS-FIM-REL = 'S'
018700         READ ARQ-ESTOQUE NEXT AT END MOVE 'S' TO WS-FIM-REL
018800             NOT AT END
018900                 DISPLAY PROD-ID LINE WS-LINHA COLUMN 10
019000                 DISPLAY PROD-NOME LINE WS-LINHA COLUMN 18
019100                 ADD 1 TO WS-LINHA
019200                 IF WS-LINHA > 20
019300                    ACCEPT WS-OPCAO
019400                    MOVE 6 TO WS-LINHA
019500                 END-IF
019600         END-READ
019700     END-PERFORM.
019800     DISPLAY "FIM." LINE WS-LINHA COLUMN 10.
019900     ACCEPT WS-OPCAO.
